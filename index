<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>大匠設計 · 香港全屋傢俬定製</title>
    <!-- Font Awesome 6 (免費) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background-color: #fef9f2;  /* 奶油色主調 */
            color: #4a3b2f;              /* 暖啡色文字 */
        }

        /* 奶油色調盤 */
        :root {
            --cream: #fef9f2;
            --light-cream: #fffbf5;
            --warm-brown: #8b6f4c;
            --soft-brown: #b99e7c;
            --pale-wood: #f0e5d8;
            --deep-cream: #faefde;
        }

        .container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 30px;
        }

        /* 導航 + logo預留位 */
        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            padding: 20px 0 15px;
            border-bottom: 2px solid #e9d9c4;
        }

        .logo-placeholder {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .logo-box {
            width: 70px;
            height: 70px;
            background: linear-gradient(145deg, #eedbc8, #dccbb6);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 5px 0 #b99e7c;
        }
        .logo-box i {
            font-size: 2.8rem;
            color: #7c6142;
        }
        .logo-text h1 {
            font-size: 2.3rem;
            font-weight: 600;
            color: #7c6142;
            letter-spacing: 1px;
            line-height: 1.1;
        }
        .logo-text p {
            color: #a48b6f;
            font-size: 1rem;
            letter-spacing: 0.5px;
        }

        .contact-links {
            display: flex;
            gap: 15px;
        }
        .contact-btn {
            background: white;
            border-radius: 50px;
            padding: 12px 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.03);
            border: 1px solid #e9d5c0;
            font-weight: 500;
            color: #5e4a35;
            text-decoration: none;
            transition: 0.2s;
        }
        .contact-btn i {
            font-size: 1.5rem;
        }
        .contact-btn .fa-whatsapp { color: #25D366; }
        .contact-btn .fa-weixin { color: #1AAD19; }
        .contact-btn:hover {
            background: #f9efdf;
            border-color: #b99e7c;
        }

        /* 主banner */
        .hero {
            background: #fdf3e6;
            border-radius: 40px;
            padding: 45px 40px;
            margin: 40px 0;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            border: 1px solid #eddbb8;
        }
        .hero-text {
            flex: 1 1 280px;
        }
        .hero-text h2 {
            font-size: 2.6rem;
            color: #7c6142;
            font-weight: 500;
        }
        .hero-highlight {
            background: #b99e7c;
            color: white;
            padding: 6px 18px;
            border-radius: 50px;
            display: inline-block;
            margin-top: 20px;
            font-size: 1.2rem;
        }
        .hero-icon {
            font-size: 6rem;
            color: #dcc09f;
        }

        /* 通用標題 */
        .section-title {
            font-size: 2.5rem;
            color: #7c6142;
            margin: 70px 0 35px;
            font-weight: 500;
            border-left: 12px solid #dcc09f;
            padding-left: 30px;
        }

        /* 四個案例圖片+文字區 */
        .cases-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
        }
        .case-card {
            background: white;
            border-radius: 32px;
            overflow: hidden;
            box-shadow: 0 12px 25px rgba(152, 116, 78, 0.08);
            border: 1px solid #eedbc8;
            transition: 0.2s;
        }
        .case-card:hover {
            transform: translateY(-8px);
        }
        .case-img {
            height: 210px;
            background: #f3e7da;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #8b6f4c;
            font-size: 4rem;
            border-bottom: 2px solid #ecd7bd;
        }
        .case-img span {
            font-size: 0.9rem;
            background: white;
            padding: 4px 12px;
            border-radius: 30px;
            margin-top: 10px;
            color: #5e4a35;
        }
        .case-info {
            padding: 22px 18px;
            background: #ffffffd9;
        }
        .case-info h3 {
            color: #7c6142;
            font-size: 1.6rem;
            font-weight: 600;
            margin-bottom: 8px;
        }
        .case-info p {
            color: #6b5842;
            line-height: 1.5;
        }

        /* 兩個Youtube視頻區 (並排) */
        .video-row {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            margin: 40px 0 20px;
        }
        .video-box {
            flex: 1 1 300px;
            background: #f5eadc;
            border-radius: 40px;
            padding: 25px 20px 30px;
            border: 2px solid #ecd1b3;
            box-shadow: inset 0 -2px 0 #b99e7c;
        }
        .video-box h3 {
            font-size: 1.7rem;
            color: #7c6142;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .video-embed {
            background: #dccbb6;
            border-radius: 30px;
            height: 240px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #5e4a35;
            font-size: 1.3rem;
            border: 2px solid #b99e7c;
            box-shadow: 0 8px 0 #9f876b;
        }
        .video-embed i {
            font-size: 4.5rem;
            color: #7c6142;
            margin-bottom: 10px;
        }
        .video-embed p {
            background: white;
            padding: 6px 20px;
            border-radius: 60px;
        }

        /* 案例收費報價區 (保留四組報價) */
        .pricing-area {
            background: #faefde;  /* 深奶油色 */
            border-radius: 60px;
            padding: 45px 35px;
            margin: 70px 0;
            border: 2px solid #ddc3a3;
        }
        .pricing-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 30px;
        }
        .pricing-title h2 {
            font-size: 2.4rem;
            color: #5e4430;
        }
        .badge-cream {
            background: white;
            padding: 12px 28px;
            border-radius: 60px;
            color: #8b6f4c;
            font-weight: 600;
            border: 1px solid #dbb99a;
        }
        .price-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
        }
        .price-card {
            background: white;
            border-radius: 35px;
            padding: 28px 15px 25px;
            text-align: center;
            border: 1px solid #c9ae8b;
            box-shadow: 0 8px 0 #c0a482, 0 10px 20px rgba(0,0,0,0.05);
        }
        .price-card i {
            font-size: 2.5rem;
            color: #b2895c;
            margin-bottom: 10px;
        }
        .price-card h4 {
            font-size: 1.6rem;
            color: #7c6142;
        }
        .price-amount {
            font-size: 2.4rem;
            font-weight: 700;
            color: #4e3b28;
            margin: 10px 0;
        }
        .price-amount small {
            font-size: 1rem;
            font-weight: 400;
            color: #b2895c;
        }
        .price-desc {
            background: #faf0e3;
            padding: 10px;
            border-radius: 60px;
            color: #4e3b28;
            font-size: 0.95rem;
        }

        /* 底部 + 聯繫連結 */
        .footer {
            background: #846b4e;  /* 暖啡色 */
            border-radius: 50px 50px 0 0;
            padding: 45px 0 30px;
            margin-top: 70px;
        }
        .footer .container {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }
        .social-foot a {
            color: #fef3e0;
            background: #9f876b;
            padding: 12px 28px;
            border-radius: 50px;
            font-size: 1.3rem;
            margin-right: 15px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            border: 1px solid #ecd1b3;
            transition: 0.2s;
        }
        .social-foot a:hover {
            background: #7c6142;
        }
        .copyright {
            color: #f0dbc6;
            font-size: 1rem;
        }

        /* 固定聯繫浮動按鈕 (微信 + whatsapp) */
        .float-contact {
            position: fixed;
            bottom: 35px;
            right: 35px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 99;
        }
        .float-btn {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            box-shadow: 0 10px 18px rgba(0,0,0,0.1);
            border: 2px solid #e7cfb4;
            text-decoration: none;
            transition: 0.1s;
        }
        .float-btn .fa-whatsapp { color: #25D366; }
        .float-btn .fa-weixin { color: #1AAD19; }
        .float-btn:hover {
            background: #8b6f4c;
            border-color: white;
        }
        .float-btn:hover i {
            color: white;
        }

        /* 響應式 */
        @media (max-width: 1000px) {
            .cases-grid, .price-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .video-row {
                flex-direction: column;
            }
        }
        @media (max-width: 700px) {
            .navbar {
                flex-direction: column;
                align-items: start;
                gap: 20px;
            }
            .cases-grid, .price-grid {
                grid-template-columns: 1fr;
            }
            .logo-box {
                width: 55px;
                height: 55px;
            }
            .logo-text h1 {
                font-size: 1.9rem;
            }
        }
    </style>
</head>
